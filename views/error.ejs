<% layout('/layouts/boilerplate') %>

    <div class="row">
        <div class="col-6 offset-3">

            <div class="alert alert-danger" role="alert">
                <h4 class="alert-heading">Oups!!</h4>
                <p>
                    <%= err.message %>
                </p>
                <hr>
                <% if (process.env.NODE_ENV !== 'production') { %>
                    <p>
                        <%= err.stack %>
                    </p>
                <% } %>
                <hr>
                <p class="mb-0">
                    Status Code: <%= err.status %>
                </p>
            </div>
        </div>
    </div>