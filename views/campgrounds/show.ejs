<% layout('./layouts/boilerplate') %>
<link rel="stylesheet" href="/stylesheets/stars.css">

<div class="container mt-5">
    <div class="row g-5">
        
        <!-- Campground Card -->
        <div class="col-lg-6 col-md-12">
            <div class="card shadow-lg border-0">
                <div id="campgroundImageCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="3000">
                        <% if (camp.images.length>1) { %>
                            <ol class="carousel-indicators">
                            <% for (let i = 0; i < camp.images.length; i++) { %>
                                <li data-bs-target="#campgroundImageCarousel" data-bs-slide-to="<%= i %>" class="<%= i === 0 ? 'active' : '' %>"></li>
                                <% } %>
                            </ol>
                        <% } %>
                        <div class="carousel-inner">
                            <% camp.images.forEach((img, i) => { %>
                                <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
                                    <img class="d-block w-100" src="<%= img.url %>" alt="">
                                </div>
                                <% }) %>
                            </div>
                            <% if (camp.images.length>1) { %>
                            <a class="carousel-control-prev" href="#campgroundImageCarousel" role="button" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Previous</span>
                            </a>
                            <a class="carousel-control-next" href="#campgroundImageCarousel" role="button" data-bs-slide="next">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Next</span>
                            </a>
                            <% } %>
                    </div>
                    <div class="card-body">
                    <h3 class="card-title mb-2"><%= camp.title %></h3>
                    <p class="text-muted mb-3">By <%= camp.author.username %></p>
                    <p class="card-text fs-5 mb-4">
                        <%= camp.description %>
                    </p>
                    <p class="card-text fw-bold fs-4">
                        <% if(camp.price == 0) { %>
                            Price: FREE
                        <% } else { %>
                            Price: <%= camp.price %> Da
                        <% } %>
                    </p>
                    <p class="card-text text-muted">
                        <small>
                            <i class="fas fa-map-marker-alt"></i> <%= camp.location %>
                        </small>
                    </p>
                    
                    <div class="d-flex justify-content-between mt-4">
                        <a href="/campgrounds" class="btn btn-secondary btn-lg">All Campgrounds</a>
                        <% if (currentUser && camp.author.equals(currentUser.id)) { %>  
                            <div class="d-flex">
                                <a href="/campgrounds/<%=camp.id %>/edit" class="btn btn-primary btn-lg me-2">Edit</a>
                                <form action="/campgrounds/<%=camp.id %>?_method=DELETE" method="POST" style="display:inline;">
                                    <button type="submit" class="btn btn-danger btn-lg">Delete</button>
                                </form>
                            </div>
                        <% }  %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Review Section -->
        <div class="col-lg-6 col-md-12">
            <div class="card shadow-lg border-0">
                <div class="card-body">
                    <% if (currentUser) { %>
                        <h2 class="card-title text-primary mb-4">Leave a Review</h2>
                        <form action="/campgrounds/<%= camp.id %>/reviews" method="POST" class="validated-form">
                            <div class="mb-3">
                                    <fieldset class="starability-slot">
                                        <legend>rating:</legend>
                                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />

                                        <input type="radio" id="rate1" name="review[rating]" value="1" />
                                        <label for="rate1">1 star.</label>

                                        <input type="radio" id="rate2" name="review[rating]" value="2" />
                                        <label for="rate2">2 stars.</label>

                                        <input type="radio" id="rate3" name="review[rating]" value="3" />
                                        <label for="rate3">3 stars.</label>

                                        <input type="radio" id="rate4" name="review[rating]" value="4" />
                                        <label for="rate4">4 stars.</label>

                                        <input type="radio" id="rate5" name="review[rating]" value="5" />
                                        <label for="rate5">5 stars.</label>

                                        <span class="starability-focus-ring"></span>
                                    </fieldset>
                            </div>
                            <div class="mb-3 form-floating">
                                <textarea class="form-control" placeholder="Please enter your review..." minlength="10" name="review[body]" id="body" style="height: 100px" required></textarea>
                                <label for="body">Review</label>
                                <div class="invalid-tooltip">Missing review!</div>
                            </div>
                            <button class="btn btn-success btn-lg">Submit Review</button>
                        </form>
                    <% } %>

                    <!-- Display Reviews -->
                    <div class="mt-5">
                        <h2 class="text-center mb-5 text-primary display-6">What People Are Saying</h2>

                        <% camp.reviews.forEach(review => { %>
                            <div class="card mb-4 shadow-lg border-0" style="background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px); border-radius: 20px;">
                                <div class="row g-0 align-items-center">

                                    <!-- Review Body with Rating and Author -->
                                    <div class="col-md-9 p-4">
                                        <div class="card-body">
                                                <p class="starability-result" data-rating="<%= review.rating %>">
                                                    Rated: <%= review.rating %> stars
                                                </p>
                                            
                                            <!-- Author Info -->
                                            <h6 class="card-subtitle mb-3 text-muted">
                                                <i class="fas fa-user-circle me-1 fs-5"></i>
                                                <span class="fw-bold">By</span> <%= review.author.username %>
                                            </h6>
                                            
                                            <!-- Review Text with Animated Quote -->
                                            <p class="card-text fs-6">
                                                <i class="fas fa-quote-left text-muted fs-4 me-2"></i>
                                                <%= review.body %>
                                            </p>
                                        </div>
                                    </div>

                                    <!-- Delete Button Section -->
                                     <% if (currentUser && review.author.id===(currentUser.id)) { %> 
                                    <div class="col-md-3 d-flex align-items-center justify-content-end p-3">
                                        <form action="/campgrounds/<%= camp.id %>/reviews/<%= review.id %>?_method=DELETE" method="POST">
                                            <button class="btn btn-danger btn-lg d-flex align-items-center shadow" style="border-radius: 30px;">
                                                <i class="fas fa-trash-alt me-2"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                    <% } %>
                                </div>
                            </div>
                        <% }) %>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
