<% layout('./layouts/boilerplate') %>
<link rel="stylesheet" href="/stylesheets/mapCluster.css">
<link rel="stylesheet" href="/stylesheets/globale.css">
<link rel="stylesheet" href="/stylesheets/index.css">


<div id="map">
</div>
<div class="container mt-5">
    <!-- Page Heading -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-4 text-primary">All Campgrounds</h1>
        <a href="/campgrounds/new" class="btn btn-success btn-lg shadow">
            <i class="fas fa-plus-circle me-2"></i> New Campground
        </a>
    </div>
     <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
     </div>
    <!-- List of Campgrounds -->
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        
        <% for(let camp of camps) { %>
            <div class="col px-3 ">
                <!-- Make the entire card clickable -->
                <a href="/campgrounds/<%= camp.id %>" class="text-decoration-none">
                    <div class="card shadow-lg border-0">
                        <div class="row g-0">
                            <!-- Campground Image -->
                            <div class="">
                                <img src="<%= camp.images[0] && (camp.images[0].url)?camp.images[0].url:'https://www.19fortyfive.com/wp-content/uploads/2021/07/Poland-M1-Abrams.jpg' %>" class="img-fluid rounded-start d-block w-100" alt="<%= camp.title %> Image">
                            </div>

                            <!-- Campground Info -->
                            <div class="col-md-7 d-flex align-items-center">
                                <div class="card-body">
                                    <!-- Title -->
                                    <h5 class="card-title">
                                        <%= camp.title %>
                                    </h5>

                                    <!-- Description -->
                                    <p class="card-text">
                                        <%= camp.description.length > 100 ? camp.description.substring(0, 100) + '...' : camp.description %>
                                    </p>

                                    <!-- Location -->
                                    <p class="card-text">
                                        <small class="">
                                            <i class="fas fa-map-marker-alt me-1"></i> <%= camp.location %>
                                        </small>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        <% } %>
    </div>
</div>

<script>
    const mapApiKey = "<%= process.env.MAPTILER_API_KEY %>";
    const campgrounds = {features:<%-JSON.stringify(camps)%>};
</script>
<script src="/javascripts/mapCluster.js"></script>