<% layout('./layouts/boilerplate') %>
    <H1>all Campgrounds</H1>
    <a href="/campgrounds/new">NEW</a>

    <ul>
        <% for( let camp of camps ) { %>


            <div class="card mb-3" style="max-width: 540px;">
                <div class="row g-0">
                    <div class="col-md-4">
                        <img src="<%= camp.image %>" class="img-fluid rounded-start" alt="...">
                    </div>
                    <div class="col-md-8">
                        <div class="card-body">
                            <h5 class="card-title"><a href="campgrounds/<%= camp.id %>">
                                    <%= camp.title %>
                                </a></h5>
                            <p class="card-text">
                                <%= camp.description %>
                            </p>
                            <p class="card-text"><small class="text-body-secondary">
                                    <%= camp.location %>
                                </small>
                            </p>
                        </div>
                    </div>
                </div>
            </div>


            <% } %>
    </ul>